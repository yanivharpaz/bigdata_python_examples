# Kerberos - Required
KRB5_REALM=EXAMPLE.COM
KRB5_KDC=kdc.example.com
KRB5_PRINCIPAL=backend@EXAMPLE.COM
KRB5_KEYTAB_PATH=/keytabs/backend.keytab

# Kerberos - Optional
KRB5_AUTH_MODE=keytab
KRB5_RENEWAL_THRESHOLD=300

# Impala - Required
IMPALA_HOST=impala.example.com
IMPALA_PORT=21050
IMPALA_DATABASE=default

# Impala - Optional
IMPALA_USE_TLS=false
IMPALA_CA_CERT=
IMPALA_POOL_MIN=2
IMPALA_POOL_MAX=10
IMPALA_QUERY_TIMEOUT=60
